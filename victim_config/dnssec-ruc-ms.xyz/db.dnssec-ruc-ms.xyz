$ORIGIN     dnssec-ruc-ms.xyz.
$TTL        3600

@           SOA     ns.dnssec-ruc-ms.xyz.      admin.dnssec-ruc-ms.xyz. (
                    2025052901; serial
                    3600      ; refresh
                    1800      ; retry
                    1209600   ; expire after 2 weeks
                    600 )     ; minimum TTL of 600 secs
;

; apex NS delegation
@           IN  NS      grannbo.ns.cloudflare.com.
@           IN  NS      koa.ns.cloudflare.com.

; domain for the basic test
test                IN  NS      ns.test.dnssec-ruc-ms.xyz.
test                IN  DS      59596 8 2 9E1D7D59D3C3A6D10C64B32B17766423C8BE93A59311F8BA9B65EBBF C749435F
ns.test             IN  A       192.168.45.70

